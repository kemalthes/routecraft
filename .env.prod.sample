# Public URLs
PUBLIC_BASE_URL=http://193.233.201.48
ALLOWED_ORIGINS=http://193.233.201.48,http://193.233.201.48:28082
ALLOWED_ORIGIN_PATTERNS=http://193.233.201.48,http://193.233.201.48:*
MINIO_PUBLIC_ENDPOINT=http://193.233.201.48:9000

# Published host ports
FRONTEND_PORT=80
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Database
POSTGRES_DB=routecraft_db
POSTGRES_USER=routecraft
POSTGRES_PASSWORD=change-me

# Redis
REDIS_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USERNAME=routecraft
